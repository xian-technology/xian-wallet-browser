{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@xian/client": ["../xian-js/packages/client/dist/index.d.ts"],
      "@xian/provider": ["../xian-js/packages/provider/dist/index.d.ts"],
      "@xian/wallet-core": ["packages/wallet-core/src/index.ts"]
    }
  }
}
